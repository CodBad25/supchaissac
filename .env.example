# SupChaissac v2 - Variables d'environnement

# ===========================================
# BASE DE DONNEES (OBLIGATOIRE)
# ===========================================
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# ===========================================
# SESSION & SECURITE (OBLIGATOIRE)
# ===========================================
SESSION_SECRET=generate-a-random-secret-here
NODE_ENV=development

# ===========================================
# STOCKAGE FICHIERS (OPTIONNEL)
# ===========================================
# Dossier de stockage local pour les uploads (défaut: ./uploads)
UPLOAD_DIR=./uploads

# ===========================================
# EMAIL (OPTIONNEL - mode présentation par défaut)
# ===========================================
EMAIL_ENABLED=false
RESEND_API_KEY=re_xxxxxxxxxxxx
APP_URL=http://localhost:5173

# ===========================================
# SERVEUR (OPTIONNEL)
# ===========================================
PORT=3001
